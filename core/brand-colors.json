      "hex": "#D91E4D",
      "rgb": { "r": 218, "g": 30, "b": 78 },
      "cmyk": { "c": 10, "m": 100, "y": 65, "k": 0 },
      "usage": ["Logo mark (butterfly/leaf element)", "Section titles in red", "Highlights in body text", "Tagline text option", "Icon fill", "Stroke lines", "CTA buttons", "Envelope header band"]
    },
    "CPI_Mid_Grey": {
      "name": "CPI Mid Grey",
      "role": "Secondary text, muted backgrounds, dividers",
