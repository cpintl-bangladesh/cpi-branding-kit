      "rgb": { "r": 75, "g": 39, "b": 67 },
      "cmyk": { "c": 55, "m": 80, "y": 35, "k": 55 },
      "usage": ["Logo wordmark", "Headings", "Body text on white/light backgrounds", "Tagline text option"]
    },
    "CPI_Red": {
      "name": "CPI Red / Magenta",
      "role": "Primary accent — CTAs, icons, highlights, stroke lines, section headers",
