      "usage": ["Panel backgrounds", "Light section fills", "Name card backgrounds"]
    },
    "CPI_Black": {
      "name": "CPI Black",
      "role": "Near-black for body text in non-branded contexts",
      "pantone": "Pantone Black C",
      "hex": "#2D2926",
      "rgb": { "r": 35, "g": 31, "b": 32 },
      "cmyk": { "c": 0, "m": 0, "y": 0, "k": 100 },
      "usage": ["Body text (general)", "Fine print", "Dark overlays"]
